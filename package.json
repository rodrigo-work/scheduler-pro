{
  "name": "aws-auth-platform",
  "private": true,
  "license": "MIT",
  "repository": "https://github.com/rodrigo-work/aws-auth-platform.git",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,tsx,ts,mjs,json,css,md}": [
      "prettier --write --no-error-on-unmatched-pattern \"src/**/*.{js,jsx,tsx,ts,mjs,json,css,md}\""
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "turbo": "^2.5.2"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": "^20.x"
  }
}
